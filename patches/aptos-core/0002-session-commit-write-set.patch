+    /// Applies a write set produced by an out-of-band execution (e.g. movelite's
+    /// instrumented trace path) to the live state store and persists it, mirroring
+    /// the commit tail of `execute_transaction`. Lets callers run the VM with a
+    /// custom gas meter and still commit through the session.
+    pub fn commit_write_set(
+        &mut self,
+        write_set: &aptos_types::write_set::WriteSet,
+    ) -> Result<()> {
+        self.state_store.apply_write_set(write_set)?;
+        self.config.ops += 1;
+        self.config.save_to_file(&self.path.join("config.json"))?;
+        save_delta(&self.path.join("delta.json"), &self.state_store.delta())?;
+        Ok(())
+    }
